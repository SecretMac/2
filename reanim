                    local iconIndex = 0
                    for i, gameIcon in ipairs({"Zombie", "Sonic", "Mario", "Minecraft", "Garry's Mod"}) do
                        if child.Name == "GameIcon_" .. gameIcon then
                            iconIndex = i
                            break
                        end
                    end
                    
                    -- Fade out with staggered timing (0.05s delay between each icon, reverse order)
                    local iconDelay = 0.05 * (iconIndex - 1)
                    
                    -- Create a custom tween info with the delay
                    local iconTweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, false, iconDelay)
                    
