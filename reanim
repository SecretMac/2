                        -- Fade in with staggered timing (0.05s delay between each icon)
                        local iconDelay = 0.05 * (iconIndex - 1)
                        
                        -- First make sure icon is the right size but transparent
                        child.Size = UDim2.new(0, iconBaseSize, 0, iconBaseSize)
                        child.ImageTransparency = 1
                        
                        -- Create a custom tween info with the delay
                        local iconTweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, false, iconDelay)
                        
                        -- Apply the fade-in tween
                        TweenService:Create(child, iconTweenInfo, {ImageTransparency = 0}):Play()
                    else
                        -- Standard UI elements
                        if child:IsA("TextLabel") or child:IsA("TextButton") then
                            TweenService:Create(child, tweenInfoFade, {TextTransparency = 0}):Play()
                        elseif child:IsA("TextBox") then
                            TweenService:Create(child, tweenInfoFade, {TextTransparency = 0, BackgroundTransparency = 0}):Play()
                        elseif child:IsA("ImageButton") or child:IsA("ImageLabel") then
                            -- For regular image elements, tween both background and image
                            TweenService:Create(child, tweenInfoFade, {BackgroundTransparency = 0, ImageTransparency = 0}):Play()
                        else
                            -- For everything else
                            TweenService:Create(child, tweenInfoFade, {BackgroundTransparency = 0}):Play()
                        end
                    end
                end
            end
        end)
    end

    local function exitEditMode()
        editMode = false
