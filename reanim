    if idleCheckConnection then
        idleCheckConnection:Disconnect()
        idleCheckConnection = nil
    end
    
    -- Reset movement tracking state
    lastMovementState = false
    
    -- Stop idle animation if it's playing
    if isPlayingIdle then
